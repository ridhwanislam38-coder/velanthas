# ── Velanthas Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your API keys.
# NEVER commit .env to git — it's in .gitignore.

# ── Supabase (required for save/leaderboard) ────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── AI Tool Pipeline (optional — for asset generation) ──────────────────────
# Get keys from:
#   RetroDiffusion: https://retrodiffusion.ai (sprite/tileset generation)
#   FreeSound:      https://freesound.org/apiv2/apply (ambient SFX)
#   ElevenLabs:     https://elevenlabs.io (voice acting)

VITE_RETRODIFFUSION_API_KEY=
VITE_FREESOUND_API_KEY=
VITE_ELEVENLABS_API_KEY=

# ── Usage ────────────────────────────────────────────────────────────────────
# After filling in keys, run:
#   npm run generate retrodiffusion   → generates Ashfields tileset sprites
#   npm run generate freesound        → downloads ambient SFX for Ashfields
#   npm run generate elevenlabs       → generates Magistra Eon voice lines
#
# Or just run the game:
#   npm run dev
